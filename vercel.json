{
  "rewrites": [
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/app/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/ai",
      "destination": "/index.html"
    },
    {
      "source": "/requests",
      "destination": "/index.html"
    },
    {
      "source": "/profile/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/request/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/ai-flow",
      "destination": "/index.html"
    }
  ]
}
